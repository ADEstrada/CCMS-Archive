<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#5E0006"
    android:padding="20dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <ImageView android:id="@+id/img_step1"
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@drawable/step1_icon" android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_vertical"
        android:layout_marginTop="10dp" android:layout_marginEnd="15dp"/>

    <TextView android:id="@+id/txt_step1"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="Create Account" android:textColor="#FFFFFF"
        android:textSize="17sp" android:fontFamily="@font/poppins_medium"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/img_step1"
        app:layout_constraintBottom_toBottomOf="@id/img_step1"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="10dp"/>

    <View android:id="@+id/line1"
        android:layout_width="2dp" android:layout_height="40dp"
        android:background="#FFFFFF" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/img_step1"
        app:layout_constraintStart_toStartOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="@id/guideline_vertical"/>

    <ImageView android:id="@+id/img_step2"
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@drawable/step2_icon" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/line1"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        android:layout_marginStart="15dp"/>

    <TextView android:id="@+id/txt_step2"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="Add Project Post" android:textColor="#FFFFFF"
        android:textSize="17sp" android:fontFamily="@font/poppins_medium"
        android:visibility="invisible" android:gravity="end"
        app:layout_constraintTop_toTopOf="@id/img_step2"
        app:layout_constraintBottom_toBottomOf="@id/img_step2"
        app:layout_constraintEnd_toStartOf="@id/guideline_vertical"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginEnd="10dp"/>

    <View android:id="@+id/line2"
        android:layout_width="2dp" android:layout_height="40dp"
        android:background="#FFFFFF" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/img_step2"
        app:layout_constraintStart_toStartOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="@id/guideline_vertical"/>

    <ImageView android:id="@+id/img_step3"
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@drawable/step3_icon" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/line2"
        app:layout_constraintEnd_toStartOf="@id/guideline_vertical"
        android:layout_marginEnd="15dp"/>

    <TextView android:id="@+id/txt_step3"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="Wait for Approval" android:textColor="#FFFFFF"
        android:textSize="17sp" android:fontFamily="@font/poppins_medium"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/img_step3"
        app:layout_constraintBottom_toBottomOf="@id/img_step3"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="10dp"/>

    <View android:id="@+id/line3"
        android:layout_width="2dp" android:layout_height="40dp"
        android:background="#FFFFFF" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/img_step3"
        app:layout_constraintStart_toStartOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="@id/guideline_vertical"/>

    <ImageView android:id="@+id/img_step4"
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@drawable/step4_icon" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/line3"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        android:layout_marginStart="15dp"/>

    <TextView android:id="@+id/txt_step4"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="Archive Projects" android:textColor="#FFFFFF"
        android:textSize="17sp" android:fontFamily="@font/poppins_medium"
        android:visibility="invisible" android:gravity="end"
        app:layout_constraintTop_toTopOf="@id/img_step4"
        app:layout_constraintBottom_toBottomOf="@id/img_step4"
        app:layout_constraintEnd_toStartOf="@id/guideline_vertical"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginEnd="10dp"/>

    <View android:id="@+id/line4"
        android:layout_width="2dp" android:layout_height="40dp"
        android:background="#FFFFFF" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/img_step4"
        app:layout_constraintStart_toStartOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="@id/guideline_vertical"/>

    <ImageView android:id="@+id/img_step5"
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@drawable/step5_icon" android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/line4"
        app:layout_constraintEnd_toStartOf="@id/guideline_vertical"
        android:layout_marginEnd="15dp"/>

    <TextView android:id="@+id/txt_step5"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="Interact with Peers" android:textColor="#FFFFFF"
        android:textSize="17sp" android:fontFamily="@font/poppins_medium"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/img_step5"
        app:layout_constraintBottom_toBottomOf="@id/img_step5"
        app:layout_constraintStart_toEndOf="@id/guideline_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="10dp"/>

    <View android:id="@+id/line5"
        android:layout_width="2dp" android:layout_height="20dp"
        android:background="@android:color/transparent"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/txt_step5"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
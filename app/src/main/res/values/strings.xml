    <string name="mission">Mission</string>
    <string name="mission_desc">To provide a centralized digital repository for the College of Computing and Multimedia Studies (CCMS), specifically for IT and IS programs. CCMS Archive aims to eliminate the frustration of academic redundancy by offering a structured platform for browsing past research, project demonstrations, and technical documentation. By making previous student outputs easily accessible, the mission is to foster a culture of innovation, streamline the topic proposal process, and promote meaningful academic collaboration between current students and past project creators.</string>

    <string name="developer">Developer</string>
    <string name="developer_desc">
        <![CDATA[
